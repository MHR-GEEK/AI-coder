AI_PROVIDER=ollama
AI_BASE_URL=https://ollama.com
AI_API_KEY=replace_with_your_provider_key
AI_MODEL=gpt-oss:120b
AI_VISION_MODEL=minimax-m3

# OpenAI-compatible hosted providers also work:
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=replace_with_your_openai_key
# AI_MODEL=gpt-4.1-mini
# AI_VISION_MODEL=gpt-4.1
